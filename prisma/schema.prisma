generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./database.sqlite"
}

model Genero {
  id     Int    @id @default(autoincrement())
  nome   String

  jogos  Jogo[]
}

model Plataforma {
  id     Int    @id @default(autoincrement())
  nome   String

  jogos  JogoPlataforma[]
}

model Jogo {
  id        Int    @id @default(autoincrement())
  titulo    String

  idGenero  Int
  genero    Genero @relation(fields: [idGenero], references: [id])

  plataformas JogoPlataforma[]
}

model JogoPlataforma {
  id            Int @id @default(autoincrement())

  jogoId        Int
  plataformaId  Int

  jogo          Jogo @relation(fields: [jogoId], references: [id])
  plataforma    Plataforma @relation(fields: [plataformaId], references: [id])
}